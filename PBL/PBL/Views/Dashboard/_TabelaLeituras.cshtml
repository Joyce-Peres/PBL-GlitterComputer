@model IEnumerable<PBL.Models.LeituraSensorViewModel>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Id</th>
            <th>Aquário</th>
            <th>Temp. Água (°C)</th>
            <th>Temp. Ar (°C)</th>
            <th>Umidade (%)</th>
            <th>TDS (ppm)</th>
            <th>LDR</th>
            <th>Nível (%)</th>
            <th>Volume (L)</th>
            <th>Data/Hora</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.NomeAquario</td>
                    <td>@(item.TemperaturaAgua.HasValue ? item.TemperaturaAgua.Value.ToString("0.0") : item.Temperatura.ToString("0.0"))</td>
                    <td>@(item.TemperaturaAr.HasValue ? item.TemperaturaAr.Value.ToString("0.0") : "-")</td>
                    <td>@(item.UmidadeAr.HasValue ? item.UmidadeAr.Value.ToString("0") + "%" : "-")</td>
                    <td>@(item.TdsPpm.HasValue ? item.TdsPpm.Value.ToString("0") : "-")</td>
                    <td>@(item.LdrRaw.HasValue ? item.LdrRaw.Value.ToString() : "-")</td>
                    <td>@(item.NivelPct.HasValue ? item.NivelPct.Value.ToString("0.0") + "%" : item.NivelAgua.ToString("0.0") + "%")</td>
                    <td>@(item.VolumeLitros.HasValue ? item.VolumeLitros.Value.ToString("0.00") + " L" : "-")</td>
                    <td>@item.DataLeitura.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="text-center text-muted">Nenhuma leitura encontrada.</td>
            </tr>
        }
    </tbody>
</table>
