@model IEnumerable<PBL.Models.LeituraSensorViewModel>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Id</th>
            <th>Aquário</th>
            <th>Temperatura (°C)</th>
            <th>pH</th>
            <th>Nível Água (%)</th>
            <th>Data/Hora</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.NomeAquario</td>
                    <td>@item.Temperatura</td>
                    <td>@item.Ph</td>
                    <td>@item.NivelAgua</td>
                    <td>@item.DataLeitura.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Nenhuma leitura encontrada.</td>
            </tr>
        }
    </tbody>
</table>
