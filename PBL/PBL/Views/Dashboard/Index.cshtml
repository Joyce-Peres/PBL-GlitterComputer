@{
    ViewData["Title"] = "Histórico do aquário";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Histórico de leituras do aquário</h2>
<hr />
<p class="lead">Veja as medições coletadas pelos sensores e acompanhe a evolução dos parâmetros do aquário.</p>
<p class="text-muted">Fonte dos dados: <strong>@ViewBag.OrigemDados</strong></p>

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
            <h5 class="card-title mb-0">Filtrar histórico</h5>
            <small class="text-muted">Combine os campos para refinar as leituras exibidas.</small>
        </div>
        <form id="formFiltroDashboard">
            <div class="form-row">
                <div class="form-group col-md-4">
                    <label for="aquarioId">Aquário</label>
                    <select id="aquarioId" name="aquarioId" class="form-control" asp-items="ViewBag.Aquarios">
                        <option value="">Todos</option>
                    </select>
                </div>
                <div class="form-group col-md-4">
                    <label for="dataInicio">Data Início</label>
                    <input type="date" id="dataInicio" name="dataInicio" class="form-control" value="@ViewBag.DataInicio" />
                </div>
                <div class="form-group col-md-4">
                    <label for="dataFim">Data Fim</label>
                    <input type="date" id="dataFim" name="dataFim" class="form-control" value="@ViewBag.DataFim" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-3">
                    <label for="temperaturaMin">Temp. Água mín (°C)</label>
                    <input type="number" step="0.1" id="temperaturaMin" name="temperaturaMin" class="form-control" value="@ViewBag.TemperaturaMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="temperaturaMax">Temp. Água máx (°C)</label>
                    <input type="number" step="0.1" id="temperaturaMax" name="temperaturaMax" class="form-control" value="@ViewBag.TemperaturaMax" />
                </div>
                <div class="form-group col-md-3">
                    <label for="tempArMin">Temp. Ar mín (°C)</label>
                    <input type="number" step="0.1" id="tempArMin" name="tempArMin" class="form-control" value="@ViewBag.TempArMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="tempArMax">Temp. Ar máx (°C)</label>
                    <input type="number" step="0.1" id="tempArMax" name="tempArMax" class="form-control" value="@ViewBag.TempArMax" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-3">
                    <label for="tdsMin">TDS mín (ppm)</label>
                    <input type="number" step="1" id="tdsMin" name="tdsMin" class="form-control" value="@ViewBag.TdsMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="tdsMax">TDS máx (ppm)</label>
                    <input type="number" step="1" id="tdsMax" name="tdsMax" class="form-control" value="@ViewBag.TdsMax" />
                </div>
                <div class="form-group col-md-3">
                    <label for="salinidadeMin">Salinidade mín (ppt)</label>
                    <input type="number" step="0.01" id="salinidadeMin" name="salinidadeMin" class="form-control" value="@ViewBag.SalinidadeMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="salinidadeMax">Salinidade máx (ppt)</label>
                    <input type="number" step="0.01" id="salinidadeMax" name="salinidadeMax" class="form-control" value="@ViewBag.SalinidadeMax" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-3">
                    <label for="nivelMin">Nível mín (%)</label>
                    <input type="number" step="0.1" id="nivelMin" name="nivelMin" class="form-control" value="@ViewBag.NivelMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="nivelMax">Nível máx (%)</label>
                    <input type="number" step="0.1" id="nivelMax" name="nivelMax" class="form-control" value="@ViewBag.NivelMax" />
                </div>
                <div class="form-group col-md-6">
                    <label for="qualidade">Qualidade / alerta contém</label>
                    <input type="text" id="qualidade" name="qualidade" class="form-control" value="@ViewBag.Qualidade" placeholder="Ex.: Boa, Ruim, Excelente" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-12 d-flex flex-wrap justify-content-end">
                    <button type="button" id="btnLimparFiltros" class="btn btn-outline-secondary mr-2 mb-2">Limpar</button>
                    <button type="button" id="btnFiltrar" class="btn btn-primary mb-2 mr-2">Filtrar</button>
                    <button type="button" id="btnAtualizar" class="btn btn-outline-primary mb-2">Atualizar</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row mb-4" id="cardsResumo">
    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Temp. Água</h6>
                <h3 id="cardTempAgua">-- °C</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Umidade</h6>
                <h3 id="cardUmidade">-- %</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Nível</h6>
                <h3 id="cardNivel">-- %</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Condutividade</h6>
                <h3 id="cardEc">--</h3>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Temperatura</h5>
                <canvas id="graficoTemperatura" height="130"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Nível da água</h5>
                <canvas id="graficoNivel" height="130"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Condutividade / TDS</h5>
                <canvas id="graficoEc" height="130"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Luminosidade</h5>
                <canvas id="graficoLdr" height="130"></canvas>
            </div>
        </div>
    </div>
</div>

<div id="resultadoDashboard">
    <p class="text-muted">Clique em Filtrar para carregar os dados.</p>
</div>

<p id="ultimaAtualizacao" class="text-muted small"></p>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let graficoTemperatura = null;
        let graficoNivel = null;
        let graficoEc = null;
        let graficoLdr = null;

        function obterParametrosFiltro() {
            return {
                aquarioId: $('#aquarioId').val() || null,
                dataInicio: $('#dataInicio').val() || null,
                dataFim: $('#dataFim').val() || null,
                temperaturaMin: $('#temperaturaMin').val() || null,
                temperaturaMax: $('#temperaturaMax').val() || null,
                tempArMin: $('#tempArMin').val() || null,
                tempArMax: $('#tempArMax').val() || null,
                tdsMin: $('#tdsMin').val() || null,
                tdsMax: $('#tdsMax').val() || null,
                salinidadeMin: $('#salinidadeMin').val() || null,
                salinidadeMax: $('#salinidadeMax').val() || null,
                nivelMin: $('#nivelMin').val() || null,
                nivelMax: $('#nivelMax').val() || null,
                qualidade: $('#qualidade').val() || null
            };
        }

        function carregarDashboard() {
            const params = obterParametrosFiltro();

            $('#resultadoDashboard').html('<p class="text-info">Carregando...</p>');

            $.get('/Dashboard/DadosFiltrados', params, function (html) {
                $('#resultadoDashboard').html(html);
                $('#ultimaAtualizacao').text('Última atualização: ' + new Date().toLocaleString());
                carregarGraficos();
            }).fail(function () {
                $('#resultadoDashboard').html(
                    '<div class="alert alert-danger">Erro ao carregar dados.</div>'
                );
            });
        }

        function carregarGraficos() {
            const params = obterParametrosFiltro();

            $.get('/Dashboard/DadosGrafico', params, function (dados) {
                if (!dados || dados.length === 0) {
                    limparCards();
                    destruirGraficos();
                    return;
                }

                const ultimo = dados[dados.length - 1];

                $('#cardTempAgua').text(formatarNumero(ultimo.tempAgua, 1) + ' °C');
                $('#cardUmidade').text(formatarNumero(ultimo.umidade, 0) + ' %');
                $('#cardNivel').text(formatarNumero(ultimo.nivel, 1) + ' %');
                $('#cardEc').text(formatarNumero(ultimo.ec, 0));

                const labels = dados.map(x => x.dataHora);

                criarGraficoTemperatura(
                    labels,
                    dados.map(x => x.tempAgua),
                    dados.map(x => x.tempAr)
                );

                criarGraficoNivel(
                    labels,
                    dados.map(x => x.nivel)
                );

                criarGraficoEc(
                    labels,
                    dados.map(x => x.ec)
                );

                criarGraficoLdr(
                    labels,
                    dados.map(x => x.ldr)
                );
            });
        }

        function criarGraficoTemperatura(labels, tempAgua, tempAr) {
            if (graficoTemperatura) graficoTemperatura.destroy();

            graficoTemperatura = new Chart(
                document.getElementById('graficoTemperatura'),
                {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Temp. Água °C',
                                data: tempAgua
                            },
                            {
                                label: 'Temp. Ar °C',
                                data: tempAr
                            }
                        ]
                    }
                }
            );
        }

        function criarGraficoNivel(labels, nivel) {
            if (graficoNivel) graficoNivel.destroy();

            graficoNivel = new Chart(
                document.getElementById('graficoNivel'),
                {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Nível da Água %',
                                data: nivel
                            }
                        ]
                    }
                }
            );
        }

        function criarGraficoEc(labels, ec) {
            if (graficoEc) graficoEc.destroy();

            graficoEc = new Chart(
                document.getElementById('graficoEc'),
                {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Condutividade / TDS',
                                data: ec
                            }
                        ]
                    }
                }
            );
        }

        function criarGraficoLdr(labels, ldr) {
            if (graficoLdr) graficoLdr.destroy();

            graficoLdr = new Chart(
                document.getElementById('graficoLdr'),
                {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Luminosidade LDR',
                                data: ldr
                            }
                        ]
                    }
                }
            );
        }

        function destruirGraficos() {
            if (graficoTemperatura) graficoTemperatura.destroy();
            if (graficoNivel) graficoNivel.destroy();
            if (graficoEc) graficoEc.destroy();
            if (graficoLdr) graficoLdr.destroy();

            graficoTemperatura = null;
            graficoNivel = null;
            graficoEc = null;
            graficoLdr = null;
        }

        function limparCards() {
            $('#cardTempAgua').text('-- °C');
            $('#cardUmidade').text('-- %');
            $('#cardNivel').text('-- %');
            $('#cardEc').text('--');
        }

        function formatarNumero(valor, casas) {
            if (valor === null || valor === undefined || isNaN(valor)) {
                return '--';
            }

            return Number(valor).toFixed(casas);
        }

        $('#btnFiltrar').click(function () {
            carregarDashboard();
        });

        $('#btnLimparFiltros').click(function () {
            // Resetar o formulário para os valores iniciais do HTML
            const form = $('#formFiltroDashboard')[0];
            if (form) form.reset();

            // Garantir que o select de aquário fique em vazio
            $('#aquarioId').val('');

            // Limpar timestamp
            $('#ultimaAtualizacao').text('');

            // Recarregar dados (todos)
            carregarDashboard();
        });

        $('#btnAtualizar').click(function () {
            carregarDashboard();
        });

        $(document).ready(function () {
            carregarDashboard();
        });
    </script>
}
