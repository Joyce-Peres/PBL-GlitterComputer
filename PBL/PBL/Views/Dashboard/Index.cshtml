@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Dashboard — Monitoramento IoT</h2>
<hr />
<p class="lead">Acompanhe o histórico das leituras do dispositivo IoT armazenado no MongoDB via STH-Comet.</p>
<p class="text-muted">Fonte ativa: <strong>@ViewBag.OrigemDados</strong></p>

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
            <h5 class="card-title mb-0">Filtros do dashboard</h5>
            <small class="text-muted">Use a combinação de campos para refinar o histórico exibido.</small>
        </div>
        <form id="formFiltroDashboard">
            <div class="form-row">
                <div class="form-group col-md-4">
                    <label for="aquarioId">Aquário</label>
                    <select id="aquarioId" name="aquarioId" class="form-control" asp-items="ViewBag.Aquarios">
                        <option value="">Todos</option>
                    </select>
                </div>
                <div class="form-group col-md-4">
                    <label for="dataInicio">Data Início</label>
                    <input type="date" id="dataInicio" name="dataInicio" class="form-control" value="@ViewBag.DataInicio" />
                </div>
                <div class="form-group col-md-4">
                    <label for="dataFim">Data Fim</label>
                    <input type="date" id="dataFim" name="dataFim" class="form-control" value="@ViewBag.DataFim" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-3">
                    <label for="temperaturaMin">Temp. Água mín (°C)</label>
                    <input type="number" step="0.1" id="temperaturaMin" name="temperaturaMin" class="form-control" value="@ViewBag.TemperaturaMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="temperaturaMax">Temp. Água máx (°C)</label>
                    <input type="number" step="0.1" id="temperaturaMax" name="temperaturaMax" class="form-control" value="@ViewBag.TemperaturaMax" />
                </div>
                <div class="form-group col-md-3">
                    <label for="tempArMin">Temp. Ar mín (°C)</label>
                    <input type="number" step="0.1" id="tempArMin" name="tempArMin" class="form-control" value="@ViewBag.TempArMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="tempArMax">Temp. Ar máx (°C)</label>
                    <input type="number" step="0.1" id="tempArMax" name="tempArMax" class="form-control" value="@ViewBag.TempArMax" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-3">
                    <label for="tdsMin">TDS mín (ppm)</label>
                    <input type="number" step="1" id="tdsMin" name="tdsMin" class="form-control" value="@ViewBag.TdsMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="tdsMax">TDS máx (ppm)</label>
                    <input type="number" step="1" id="tdsMax" name="tdsMax" class="form-control" value="@ViewBag.TdsMax" />
                </div>
                <div class="form-group col-md-3">
                    <label for="salinidadeMin">Salinidade mín (ppt)</label>
                    <input type="number" step="0.01" id="salinidadeMin" name="salinidadeMin" class="form-control" value="@ViewBag.SalinidadeMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="salinidadeMax">Salinidade máx (ppt)</label>
                    <input type="number" step="0.01" id="salinidadeMax" name="salinidadeMax" class="form-control" value="@ViewBag.SalinidadeMax" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-3">
                    <label for="nivelMin">Nível mín (%)</label>
                    <input type="number" step="0.1" id="nivelMin" name="nivelMin" class="form-control" value="@ViewBag.NivelMin" />
                </div>
                <div class="form-group col-md-3">
                    <label for="nivelMax">Nível máx (%)</label>
                    <input type="number" step="0.1" id="nivelMax" name="nivelMax" class="form-control" value="@ViewBag.NivelMax" />
                </div>
                <div class="form-group col-md-6">
                    <label for="qualidade">Qualidade / alerta contém</label>
                    <input type="text" id="qualidade" name="qualidade" class="form-control" value="@ViewBag.Qualidade" placeholder="Ex.: Boa, Ruim, Excelente" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-12 d-flex flex-wrap justify-content-end">
                    <button type="button" id="btnLimparFiltros" class="btn btn-outline-secondary mr-2 mb-2">Limpar</button>
                    <button type="button" id="btnFiltrar" class="btn btn-primary mb-2">Filtrar</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row mb-4" id="cardsResumo">
    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Temp. Água</h6>
                <h3 id="cardTempAgua">-- °C</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Umidade</h6>
                <h3 id="cardUmidade">-- %</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Nível</h6>
                <h3 id="cardNivel">-- %</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Condutividade</h6>
                <h3 id="cardEc">--</h3>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Temperatura</h5>
                <canvas id="graficoTemperatura" height="130"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Nível da água</h5>
                <canvas id="graficoNivel" height="130"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Condutividade / TDS</h5>
                <canvas id="graficoEc" height="130"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Luminosidade</h5>
                <canvas id="graficoLdr" height="130"></canvas>
            </div>
        </div>
    </div>
</div>

<div id="resultadoDashboard">
    <p class="text-muted">Clique em Filtrar para carregar os dados.</p>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let graficoTemperatura = null;
        let graficoNivel = null;
        let graficoEc = null;
        let graficoLdr = null;

        function valorNumero(valor, fallback = 0) {
            if (valor === null || valor === undefined || valor === '') return fallback;
            const numero = Number(valor);
            return Number.isNaN(numero) ? fallback : numero;
        }

        function formatar(valor, casas = 1, sufixo = '') {
            if (valor === null || valor === undefined || valor === '') return '--' + sufixo;
            const numero = Number(valor);
            if (Number.isNaN(numero)) return '--' + sufixo;
            return numero.toFixed(casas) + sufixo;
        }

        function criarOuAtualizarGrafico(instancia, canvasId, tipo, labels, datasets) {
            if (instancia) instancia.destroy();

            return new Chart(document.getElementById(canvasId), {
                type: tipo,
                data: {
                    labels: labels,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            display: true
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false
                        }
                    }
                }
            });
        }

        function limparGraficos() {
            if (graficoTemperatura) graficoTemperatura.destroy();
            if (graficoNivel) graficoNivel.destroy();
            if (graficoEc) graficoEc.destroy();
            if (graficoLdr) graficoLdr.destroy();

            graficoTemperatura = null;
            graficoNivel = null;
            graficoEc = null;
            graficoLdr = null;
        }

        function parametrosFiltro() {
            return $('#formFiltroDashboard').serialize();
        }

        function carregarGraficos() {
            const parametros = parametrosFiltro();

            $.get('/Dashboard/DadosGrafico', parametros, function (dados) {
                if (!dados || dados.length === 0) {
                    limparGraficos();
                    $('#cardTempAgua').text('-- °C');
                    $('#cardUmidade').text('-- %');
                    $('#cardNivel').text('-- %');
                    $('#cardEc').text('--');
                    return;
                }

                const ultimo = dados[dados.length - 1];

                $('#cardTempAgua').text(formatar(ultimo.tempAgua, 1, ' °C'));
                $('#cardUmidade').text(formatar(ultimo.umidade, 0, ' %'));
                $('#cardNivel').text(formatar(ultimo.nivel, 1, ' %'));
                $('#cardEc').text(formatar(ultimo.ec, 0, ''));

                const labels = dados.map(x => x.dataHora);
                const tempAgua = dados.map(x => valorNumero(x.tempAgua, null));
                const tempAr = dados.map(x => valorNumero(x.tempAr, null));
                const nivel = dados.map(x => valorNumero(x.nivel, null));
                const ec = dados.map(x => valorNumero(x.ec, null));
                const ldr = dados.map(x => valorNumero(x.ldr, null));

                graficoTemperatura = criarOuAtualizarGrafico(
                    graficoTemperatura,
                    'graficoTemperatura',
                    'line',
                    labels,
                    [
                        {
                            label: 'Temp. Água (°C)',
                            data: tempAgua,
                            tension: 0.25
                        },
                        {
                            label: 'Temp. Ar (°C)',
                            data: tempAr,
                            tension: 0.25
                        }
                    ]
                );

                graficoNivel = criarOuAtualizarGrafico(
                    graficoNivel,
                    'graficoNivel',
                    'line',
                    labels,
                    [
                        {
                            label: 'Nível da Água (%)',
                            data: nivel,
                            tension: 0.25
                        }
                    ]
                );

                graficoEc = criarOuAtualizarGrafico(
                    graficoEc,
                    'graficoEc',
                    'line',
                    labels,
                    [
                        {
                            label: 'Condutividade / TDS',
                            data: ec,
                            tension: 0.25
                        }
                    ]
                );

                graficoLdr = criarOuAtualizarGrafico(
                    graficoLdr,
                    'graficoLdr',
                    'bar',
                    labels,
                    [
                        {
                            label: 'LDR',
                            data: ldr
                        }
                    ]
                );
            }).fail(function () {
                console.warn('Não foi possível carregar os gráficos do dashboard.');
            });
        }

        function carregarDashboard() {
            var params = parametrosFiltro();

            $('#resultadoDashboard').html('<p class="text-info">Carregando...</p>');

            $.get('/Dashboard/DadosFiltrados', params, function (html) {
                $('#resultadoDashboard').html(html);
                carregarGraficos();
            }).fail(function () {
                $('#resultadoDashboard').html('<div class="alert alert-danger">Erro ao carregar dados.</div>');
            });
        }

        $('#btnFiltrar').click(carregarDashboard);
        $('#btnLimparFiltros').click(function () {
            $('#formFiltroDashboard')[0].reset();
            carregarDashboard();
        });

        $(document).ready(function () {
            carregarDashboard();

            setInterval(function () {
                carregarDashboard();
            }, 10000);
        });
    </script>
}
