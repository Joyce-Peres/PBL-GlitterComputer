<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aquário Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">Aquário Inteligente</a>
                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav mr-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (ViewBag.Logado == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Aquario" asp-action="Index">Aquários</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Peixe" asp-action="Index">Peixes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" data-toggle="dropdown">Smart Lamp</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" asp-controller="SmartLamp" asp-action="Personalizar">Personalização</a>
                                    <a class="dropdown-item" asp-controller="SmartLamp" asp-action="Dashboard">Dashboard (Luz)</a>
                                </div>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" data-toggle="dropdown">Consultas</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" asp-controller="Consulta" asp-action="Peixes">Peixes</a>
                                    <a class="dropdown-item" asp-controller="Consulta" asp-action="Leituras">Leituras IoT</a>
                                </div>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Sobre" asp-action="Index">Sobre</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/swagger" target="_blank">API Swagger</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Login" asp-action="LogOff">Logoff</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Login" asp-action="Index">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Login" asp-action="Cadastrar">Cadastrar</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Sobre" asp-action="Index">Sobre</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <!-- Hero / banner -->
    <section class="site-hero pb-5">
        <div class="container text-center text-white">
            <h1 class="hero-title">Aquário Inteligente</h1>
            <p class="hero-sub">Monitore, proteja e personalize seu aquário com recomendações geradas por IA.</p>
            <p class="mt-4">
                <a class="btn btn-primary btn-lg hero-cta" asp-controller="Peixe" asp-action="Index">Ver catálogo de peixes</a>
            </p>
        </div>
        <svg class="hero-wave" viewBox="0 0 1200 120" preserveAspectRatio="none" aria-hidden="true">
            <path d="M0,0 C300,100 900,0 1200,80 L1200,120 L0,120 Z" fill="rgba(255,255,255,0.8)"></path>
        </svg>
    </section>
    @await Html.PartialAsync("_ProductAlerts")
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GlitterComputer - Aquário Inteligente PBL
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
