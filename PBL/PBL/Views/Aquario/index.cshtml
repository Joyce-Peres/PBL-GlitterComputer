@model IEnumerable<PBL.Models.AquarioViewModel>
@{
    ViewData["Title"] = "Aquários";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Aquários Cadastrados</h2>
<hr />
@if (TempData["Mensagem"] != null)
{
    <div class="alert alert-success">@TempData["Mensagem"]</div>
}
<p>
    <a class="btn btn-success" asp-action="Create">Novo Aquário</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Capacidade (L)</th>
            <th>Tipo de Água</th>
            <th>Responsável</th>
            <th>Entidade FIWARE</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nome</td>
                <td>@item.CapacidadeLitros</td>
                <td>@item.TipoAgua</td>
                <td>@item.NomeUsuario</td>
                <td>@(!string.IsNullOrWhiteSpace(item.FiwareEntityId) ? item.FiwareEntityId : "-")</td>
                <td>
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id"
                       title="Abrir confirmação de exclusão">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
