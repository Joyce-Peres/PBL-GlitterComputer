@model PBL.Models.SmartLampConfigViewModel
@{
    ViewData["Title"] = "Monitoramento IoT";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Monitoramento IoT</h2>
<hr />

@if (ViewBag.Mensagem != null)
{
    <div class="alert alert-success">@ViewBag.Mensagem</div>
}

<form asp-action="Salvar" method="post" class="card mb-4">
    <div class="card-header card-header-palette-aqua">
        <h5 class="mb-0">Configuração do dispositivo</h5>
    </div>
    <div class="card-body">
        <div class="form-row">
            <div class="form-group col-md-4">
                <label for="AquarioId">Aquário / dispositivo</label>
                <select class="form-control" asp-for="AquarioId" asp-items="ViewBag.Aquarios">
                    <option value="">Selecione</option>
                </select>
            </div>

            <div class="form-group col-md-4">
                <label for="Modo">Modo</label>
                <select class="form-control" asp-for="Modo" asp-items="ViewBag.Modos"></select>
            </div>

            <div class="form-group col-md-4">
                <label for="Brilho">Brilho (0-100)</label>
                <input class="form-control" type="number" min="0" max="100" id="Brilho" name="Brilho" value="@Model.Brilho" />
            </div>

            <div class="form-group col-md-4">
                <label>Última atualização</label>
                <input class="form-control" readonly value="@(Model.AtualizadoEm.HasValue ? Model.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm") : "-")" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group col-md-3">
                <label>Cor</label>
                <input class="form-control" type="color" id="corPicker" value="#ffffff" />
                <small class="text-muted">A cor será enviada como RGB.</small>
            </div>

            <div class="form-group col-md-3">
                <label for="R">R</label>
                <input class="form-control" type="number" min="0" max="255" id="R" name="R" value="@Model.R" />
            </div>
            <div class="form-group col-md-3">
                <label for="G">G</label>
                <input class="form-control" type="number" min="0" max="255" id="G" name="G" value="@Model.G" />
            </div>
            <div class="form-group col-md-3">
                <label for="B">B</label>
                <input class="form-control" type="number" min="0" max="255" id="B" name="B" value="@Model.B" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group col-md-6">
                <label for="LuzAlvo">Luz alvo (0-100) — automático (opcional)</label>
                <input class="form-control" type="number" min="0" max="100" id="LuzAlvo" name="LuzAlvo" value="@(Model.LuzAlvo.HasValue ? Model.LuzAlvo.Value.ToString() : "")" />
                <small class="text-muted">Quando o peixe for detectado pela IA, este alvo pode ser atualizado automaticamente.</small>
            </div>
            <div class="form-group col-md-6">
                <label for="TempAlvo">Temperatura alvo (°C) — automático (opcional)</label>
                <input class="form-control" type="number" step="0.1" id="TempAlvo" name="TempAlvo" value="@(Model.TempAlvo.HasValue ? Model.TempAlvo.Value.ToString() : "")" />
            </div>
        </div>

        <button type="submit" class="btn btn-palette-pink">Salvar e publicar</button>
    </div>
</form>

<section class="lamp-dashboard" aria-labelledby="lamp-dashboard-title">
    <h3 id="lamp-dashboard-title" class="menu-section-title">Painel de monitoramento</h3>
    <p class="menu-section-desc mb-3">Leitura em tempo real via MQTT e histórico da sessão atual.</p>

    <div class="card mb-3">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="card-title mb-0">Leitura atual</h5>
                    <div class="display-4" id="valorAtual">--</div>
                    <div class="text-muted" id="statusMqtt">desconectado</div>
                </div>
                <div class="col-md-6">
                    <h5 class="card-title">Histórico (sessão)</h5>
                    <p class="text-muted mb-0">Os valores recebidos pelo sensor são exibidos no gráfico abaixo.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <canvas id="chartLum" height="90"></canvas>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/mqtt/dist/mqtt.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var brokerUrl = '@(ViewBag.BrokerUrl ?? "")';
            var topicSensor = '@(ViewBag.TopicSensor ?? "")';

            function toHex(n) {
                var h = parseInt(n || 0).toString(16);
                return h.length === 1 ? '0' + h : h;
            }
            function syncPickerFromRgb() {
                var r = $('#R').val(), g = $('#G').val(), b = $('#B').val();
                $('#corPicker').val('#' + toHex(r) + toHex(g) + toHex(b));
            }
            function syncRgbFromPicker(hex) {
                var r = parseInt(hex.substr(1, 2), 16);
                var g = parseInt(hex.substr(3, 2), 16);
                var b = parseInt(hex.substr(5, 2), 16);
                $('#R').val(r);
                $('#G').val(g);
                $('#B').val(b);
            }

            $('#corPicker').on('input', function () { syncRgbFromPicker($(this).val()); });
            $('#R,#G,#B').on('input', syncPickerFromRgb);
            syncPickerFromRgb();

            if (!brokerUrl || !topicSensor) {
                $('#statusMqtt').text('MQTT não configurado no appsettings.json');
                return;
            }

            var labels = [];
            var data = [];
            var maxPoints = 60;

            var ctx = document.getElementById('chartLum').getContext('2d');
            var chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Luminosidade (%)',
                        data: data,
                        borderColor: '#5a9e9a',
                        backgroundColor: 'rgba(184, 235, 233, 0.25)',
                        borderWidth: 2,
                        tension: 0.2,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    animation: false,
                    scales: {
                        y: { min: 0, max: 100 }
                    }
                }
            });

            function setStatus(text) { $('#statusMqtt').text(text); }

            var client = mqtt.connect(brokerUrl, {
                connectTimeout: 5000,
                keepalive: 60,
                clientId: 'pbl_lamp_' + Math.random().toString(36).substr(2, 8),
                reconnectPeriod: 3000
            });

            client.on('connect', function () {
                setStatus('conectado');
                client.subscribe(topicSensor);
            });
            client.on('offline', function () { setStatus('offline'); });
            client.on('error', function () { setStatus('erro'); });

            client.on('message', function (topic, msg) {
                if (topic !== topicSensor) return;

                // O ESP32 publica JSON completo, ex: {"ldr_raw":2359,"temp_agua":22}
                // Precisamos parsear o JSON e extrair ldr_raw (0-4095) → normalizar 0-100
                var v = 0;
                try {
                    var parsed = JSON.parse(msg.toString());
                    if (parsed && typeof parsed.ldr_raw === 'number') {
                        // ldr_raw já vem invertido no firmware (4095 - raw),
                        // então 0 = escuro, 4095 = luz máxima → normaliza para 0-100
                        v = Math.round((parsed.ldr_raw / 4095) * 100);
                        v = Math.max(0, Math.min(100, v));
                    }
                } catch (e) {
                    // fallback: se por algum motivo vier valor simples
                    v = parseInt(msg.toString()) || 0;
                    v = Math.max(0, Math.min(100, v));
                }

                $('#valorAtual').text(v + ' %');

                var now = new Date();
                var t = now.toLocaleTimeString();
                labels.push(t);
                data.push(v);
                if (labels.length > maxPoints) { labels.shift(); data.shift(); }
                chart.update('none');
            });
        })();
    </script>
}
