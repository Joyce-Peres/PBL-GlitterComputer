@{
    ViewData["Title"] = "Dashboard da Smart Lamp";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Dashboard — Smart Lamp (Luminosidade)</h2>
<hr />

<div class="card mb-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <h5 class="card-title mb-0">Leitura atual</h5>
                <div class="display-4" id="valorAtual">--</div>
                <div class="text-muted" id="statusMqtt">desconectado</div>
            </div>
            <div class="col-md-6">
                <h5 class="card-title">Histórico (sessão)</h5>
                <p class="text-muted mb-0">Coleta em tempo real via MQTT e desenha o gráfico abaixo.</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <canvas id="chartLum" height="90"></canvas>
    </div>
</div>

<p class="mt-3">
    <a asp-action="Personalizar" class="btn btn-outline-primary">Voltar para personalização</a>
</p>

@section Scripts {
    <script src="https://unpkg.com/mqtt/dist/mqtt.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var brokerUrl = '@(ViewBag.BrokerUrl ?? "")';
            var topicSensor = '@(ViewBag.TopicSensor ?? "")';
            if (!brokerUrl || !topicSensor) {
                $('#statusMqtt').text('MQTT não configurado no appsettings.json');
                return;
            }

            var labels = [];
            var data = [];
            var maxPoints = 60;

            var ctx = document.getElementById('chartLum').getContext('2d');
            var chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Luminosidade (%)',
                        data: data,
                        borderWidth: 2,
                        tension: 0.2
                    }]
                },
                options: {
                    responsive: true,
                    animation: false,
                    scales: {
                        y: { min: 0, max: 100 }
                    }
                }
            });

            function setStatus(text) { $('#statusMqtt').text(text); }

            var client = mqtt.connect(brokerUrl, {
                connectTimeout: 5000,
                keepalive: 60,
                clientId: 'pbl_dash_' + Math.random().toString(36).substr(2, 8),
                reconnectPeriod: 3000
            });

            client.on('connect', function () {
                setStatus('conectado');
                client.subscribe(topicSensor);
            });
            client.on('offline', function () { setStatus('offline'); });
            client.on('error', function () { setStatus('erro'); });

            client.on('message', function (topic, msg) {
                if (topic !== topicSensor) return;
                var v = parseInt(msg.toString()) || 0;
                v = Math.max(0, Math.min(100, v));

                $('#valorAtual').text(v + ' %');

                var now = new Date();
                var t = now.toLocaleTimeString();
                labels.push(t);
                data.push(v);
                if (labels.length > maxPoints) { labels.shift(); data.shift(); }
                chart.update('none');
            });
        })();
    </script>
}
