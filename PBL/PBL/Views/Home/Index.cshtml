@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Home";
}

<h1>Menu</h1>
<hr />

<div class="menu-card">
    <h2 class="menu-hello">Olá, @(string.IsNullOrWhiteSpace(ViewBag.UsuarioNome as string) ? "!" : (ViewBag.UsuarioNome + "!"))</h2>
    <p class="menu-sub">
        Monitore temperatura, pH e nível de água do seu aquário em tempo real com sensores IoT e gerencie peixes e aquários
        pelo sistema web.
    </p>

    @if (ViewBag.Logado == true)
    {
        <div class="menu-actions">
            <a class="btn btn-primary" asp-controller="Peixe" asp-action="Index">Ver catálogo de peixes</a>
            <a class="btn btn-success" asp-controller="Aquario" asp-action="Create">Novo aquário</a>
            <a class="btn btn-info" asp-controller="Dashboard" asp-action="Index">Dashboard IoT</a>
        </div>
    }
    else
    {
        <div class="menu-actions">
            <a class="btn btn-login" asp-controller="Login" asp-action="Index">Entrar</a>
            <a class="btn btn-signup" asp-controller="Login" asp-action="Cadastrar">Cadastrar</a>
        </div>
    }
</div>

<div class="row">
    <div class="col-md-4">
        <h3>Gerencie</h3>
        <p>Cadastre aquários e peixes com fotos, vinculados ao responsável e ao aquário.</p>
    </div>
    <div class="col-md-4">
        <h3>Monitore</h3>
        <p>Acompanhe leituras dos sensores IoT no dashboard com filtros por aquário e período.</p>
    </div>
    <div class="col-md-4">
        <h3>Integre</h3>
        <p>Utilize a API REST documentada no Swagger para receber dados do dispositivo IoT.</p>
    </div>
</div>
