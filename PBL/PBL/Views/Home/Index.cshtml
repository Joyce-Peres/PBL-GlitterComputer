@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Home";
}

<h1>Aquário Inteligente</h1>
<hr />

<div class="jumbotron bg-light">
    <h2>Bem-vindo!</h2>
    <p class="lead">
        Monitore temperatura, pH e nível de água do seu aquário em tempo real
        com sensores IoT e gerencie peixes e aquários pelo sistema web.
    </p>

    @if (ViewBag.Logado == true)
    {
        <p>
            <a class="btn btn-primary btn-lg" asp-controller="Aquario" asp-action="Create">Novo Aquário &raquo;</a>
            <a class="btn btn-success btn-lg" asp-controller="Peixe" asp-action="Create">Cadastrar Peixe &raquo;</a>
            <a class="btn btn-info btn-lg" asp-controller="Dashboard" asp-action="Index">Dashboard IoT &raquo;</a>
        </p>
    }
    else
    {
        <p>
            <a class="btn btn-success btn-lg" asp-controller="Login" asp-action="Index">Faça Login &raquo;</a>
            <a class="btn btn-primary btn-lg" asp-controller="Login" asp-action="Cadastrar">Cadastre-se &raquo;</a>
        </p>
    }
</div>

<div class="row">
    <div class="col-md-4">
        <h3>Gerencie</h3>
        <p>Cadastre aquários e peixes com fotos, vinculados ao responsável e ao aquário.</p>
    </div>
    <div class="col-md-4">
        <h3>Monitore</h3>
        <p>Acompanhe leituras dos sensores IoT no dashboard com filtros por aquário e período.</p>
    </div>
    <div class="col-md-4">
        <h3>Integre</h3>
        <p>Utilize a API REST documentada no Swagger para receber dados do dispositivo IoT.</p>
    </div>
</div>
