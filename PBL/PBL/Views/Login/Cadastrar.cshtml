@{
    ViewData["Title"] = "Cadastro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Cadastro de Usuário</h2>

<div class="row">
    <div class="col-lg-4">
        <form action="/login/FazCadastro" method="post">
            <div class="form-group">
                <label for="nome" class="control-label">Nome Completo</label>
                <input type="text" name="nome" class="form-control" required placeholder='Seu nome' />
            </div>

            <div class="form-group">
                <label for="login" class="control-label">E-mail</label>
                <input type="email" name="login" class="form-control" required placeholder='seu@email.com' />
            </div>

            <div class="form-group">
                <label for="senha" class="control-label">Senha</label>
                <input type="password" name="senha" class="form-control" required placeholder='Senha...' />
            </div>

            <div class="form-group">
                <label for="confirmarSenha" class="control-label">Confirmar Senha</label>
                <input type="password" name="confirmarSenha" class="form-control" required placeholder='Confirme a senha...' />
            </div>

            <button type="submit" class="btn btn-success">Cadastrar</button>
            <a href="/login/Index" class="btn btn-secondary">Voltar</a>

            @if (!string.IsNullOrEmpty(ViewBag.Erro))
            {
                <div class="alert alert-danger mt-2">
                    @ViewBag.Erro
                </div>
            }
        </form>
    </div>
</div>
