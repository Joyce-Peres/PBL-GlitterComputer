@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2>Login</h2>
<div class="row">
    <div class="col-lg-4">
        @if (!string.IsNullOrEmpty(ViewBag.Sucesso))
        {
            <div class="alert alert-success">
                @ViewBag.Sucesso
            </div>
        }

        <form action="/login/Fazlogin" method="post">
            <div class="form-group">
                <label for="usuario" class="control-label">E-mail</label>
                <input type="email" name="usuario" class="form-control" required placeholder='seu@email.com' />
            </div>

            <div class="form-group">
                <label for="senha" class="control-label">Senha</label>
                <input type="password" name="senha" class="form-control" required placeholder='Senha...' />
            </div>

            <button type="submit" class="btn btn-success">Login</button>
            <a href="/login/Cadastrar" class="btn btn-info">Cadastre-se</a>

            @if (!string.IsNullOrEmpty(ViewBag.Erro))
            {
                <div class="alert alert-danger mt-2">
                    @ViewBag.Erro
                </div>
            }
        </form>
    </div>
</div>

