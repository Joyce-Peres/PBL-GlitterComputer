@model IEnumerable<PBL.Models.PeixeViewModel>
@{
    ViewData["Title"] = "Consulta de Peixes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Consulta Gerencial — Peixes</h2>
<hr />

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Filtros (mínimo 2)</h5>
        <form id="formFiltroPeixes" method="get" asp-action="Peixes" class="form-row">
            <div class="form-group col-md-4">
                <label for="nome">Nome</label>
                <input type="text" id="nome" name="nome" class="form-control" value="@ViewBag.NomeFiltro" placeholder="Parte do nome..." />
            </div>
            <div class="form-group col-md-4">
                <label for="especie">Espécie</label>
                <input type="text" id="especie" name="especie" class="form-control" value="@ViewBag.EspecieFiltro" placeholder="Parte da espécie..." />
            </div>
            <div class="form-group col-md-4">
                <label for="aquarioId">Aquário</label>
                <select id="aquarioId" name="aquarioId" class="form-control" asp-items="ViewBag.Aquarios">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="form-group col-12">
                <button type="button" id="btnFiltrarPeixes" class="btn btn-primary">Filtrar (Ajax)</button>
                <button type="submit" class="btn btn-secondary">Filtrar (página)</button>
            </div>
        </form>
    </div>
</div>

<div id="resultadoPeixes">
    @{ await Html.RenderPartialAsync("_TabelaPeixes", Model); }
</div>

@section Scripts {
    <script>
        $('#btnFiltrarPeixes').click(function () {
            var params = {
                nome: $('#nome').val(),
                especie: $('#especie').val(),
                aquarioId: $('#aquarioId').val() || null
            };
            $.get('/Consulta/PeixesAjax', params, function (html) {
                $('#resultadoPeixes').html(html);
            });
        });
    </script>
}
