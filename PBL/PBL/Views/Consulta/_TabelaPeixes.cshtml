@model IEnumerable<PBL.Models.PeixeViewModel>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Peixes filtrados</h6>
                <h3>@ViewBag.TotalPeixes</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Espécies distintas</h6>
                <h3>@ViewBag.TotalEspecies</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Com foto</h6>
                <h3>@ViewBag.ComFoto</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Parâmetros completos</h6>
                <h3>@ViewBag.ComParametrosCompletos</h3>
            </div>
        </div>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Espécie</th>
            <th>Temp. ideal</th>
            <th>Luz ideal</th>
            <th>TDS ideal</th>
            <th>Salinidade ideal</th>
            <th>Volume mín.</th>
            <th>Tamanho (cm)</th>
            <th>Aquário</th>
            <th>Foto</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Nome</td>
                    <td>@item.Especie</td>
                    <td>@(item.TemperaturaIdeal.HasValue ? item.TemperaturaIdeal.Value.ToString("0.0") + " °C" : "-")</td>
                    <td>@(item.LuminosidadeIdeal.HasValue ? item.LuminosidadeIdeal.Value.ToString() + " %" : "-")</td>
                    <td>@(item.TdsPpmMin.HasValue || item.TdsPpmMax.HasValue ? string.Format("{0} - {1} ppm", item.TdsPpmMin.HasValue ? item.TdsPpmMin.Value.ToString("0") : "-", item.TdsPpmMax.HasValue ? item.TdsPpmMax.Value.ToString("0") : "-") : "-")</td>
                    <td>@(item.SalinidadePptMin.HasValue || item.SalinidadePptMax.HasValue ? string.Format("{0} - {1} ppt", item.SalinidadePptMin.HasValue ? item.SalinidadePptMin.Value.ToString("0.00") : "-", item.SalinidadePptMax.HasValue ? item.SalinidadePptMax.Value.ToString("0.00") : "-") : "-")</td>
                    <td>@(item.VolumeMinLitros.HasValue ? item.VolumeMinLitros.Value.ToString("0.0") + " L" : "-")</td>
                    <td>@item.TamanhoCm</td>
                    <td>@item.NomeAquario</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Foto))
                        {
                            <img src="@item.Foto" alt="Foto" style="max-height:40px;" />
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="11" class="text-center text-muted">Nenhum registro encontrado.</td>
            </tr>
        }
    </tbody>
</table>
