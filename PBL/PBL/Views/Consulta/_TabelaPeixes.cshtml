@model IEnumerable<PBL.Models.PeixeViewModel>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Espécie</th>
            <th>Tamanho (cm)</th>
            <th>Aquário</th>
            <th>Foto</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Nome</td>
                    <td>@item.Especie</td>
                    <td>@item.TamanhoCm</td>
                    <td>@item.NomeAquario</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Foto))
                        {
                            <img src="@item.Foto" alt="Foto" style="max-height:40px;" />
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Nenhum registro encontrado.</td>
            </tr>
        }
    </tbody>
</table>
