@model IEnumerable<PBL.Models.PeixeViewModel>
@{
    ViewData["Title"] = "Peixes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Peixes Cadastrados</h2>
<hr />
@if (TempData["Mensagem"] != null)
{
    <div class="alert alert-success">@TempData["Mensagem"]</div>
}
<p>
    <a class="btn btn-success" asp-action="Create">Novo Peixe</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Id</th>
            <th>Foto</th>
            <th>Nome</th>
            <th>Espécie</th>
            <th>Temp. ideal</th>
            <th>Luz ideal</th>
            <th>TDS ideal</th>
            <th>Volume mín.</th>
            <th>Tamanho (cm)</th>
            <th>Aquário</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Foto))
                    {
                        <img src="@item.Foto" alt="Foto" style="max-height:50px;" />
                    }
                    else
                    {
                        <span class="text-muted">Sem foto</span>
                    }
                </td>
                <td>@item.Nome</td>
                <td>@item.Especie</td>
                <td>@(item.TemperaturaIdeal.HasValue ? item.TemperaturaIdeal.Value.ToString("0.0") + " °C" : "-")</td>
                <td>@(item.LuminosidadeIdeal.HasValue ? item.LuminosidadeIdeal.Value.ToString() + " %" : "-")</td>
                <td>@(item.TdsPpmMin.HasValue || item.TdsPpmMax.HasValue ? string.Format("{0} - {1} ppm", item.TdsPpmMin.HasValue ? item.TdsPpmMin.Value.ToString("0") : "-", item.TdsPpmMax.HasValue ? item.TdsPpmMax.Value.ToString("0") : "-") : "-")</td>
                <td>@(item.VolumeMinLitros.HasValue ? item.VolumeMinLitros.Value.ToString("0.0") + " L" : "-")</td>
                <td>@item.TamanhoCm</td>
                <td>@item.NomeAquario</td>
                <td>
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id"
                       onclick="return confirm('Deseja excluir este peixe? Esta ação não pode ser desfeita.');">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
